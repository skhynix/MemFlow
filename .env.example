# MemFlow Environment Configuration
# Copy this file to .env and customize as needed
# cp .env.example .env

# ===========================================
# LLM Configuration
# ===========================================
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_API_BASE=http://localhost:11434
LLM_API_KEY=

# ===========================================
# Backend Configuration
# ===========================================
# Choose one: emulated | file | memmachine | pgvector
MEMFLOW_BACKEND=emulated # default

# File Backend (MEMFLOW_BACKEND=file)
MEMFLOW_FILE_DIR=./file_data

# MemMachine Backend (MEMFLOW_BACKEND=memmachine)
MEMMACHINE_BASE_URL=http://localhost:8080
MEMMACHINE_ORG_ID=default
MEMMACHINE_PROJECT=memflow
MEMMACHINE_API_KEY=

# PgVector Backend (MEMFLOW_BACKEND=pgvector)
PGVECTOR_BASE_URL=postgresql://pgvector:pgvector_password@localhost:5433/pgvector
PGVECTOR_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
PGVECTOR_EMBEDDING_API_BASE=http://localhost:8001/v1 # Required
PGVECTOR_EMBEDDING_API_KEY=EMPTY
PGVECTOR_EMBEDDING_DIMENSIONS=2560
