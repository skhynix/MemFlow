# MemFlow Environment Configuration
# Copy this file to .env and customize as needed
# cp .env.example .env

# ===========================================
# LLM Configuration
# ===========================================
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_API_BASE=http://localhost:11434
LLM_API_KEY=

# ===========================================
# Backend Configuration
# ===========================================
# Backend: emulated
MEMFLOW_BACKEND=emulated

# Backend: file
MEMFLOW_DATA_DIR=./memflow_data

# Backend: memmachine
MEMMACHINE_BASE_URL=http://localhost:8080
MEMMACHINE_ORG_ID=default
MEMMACHINE_PROJECT=memflow
MEMMACHINE_API_KEY=

# Backend: memflow
MEMFLOW_BASE_URL=postgresql://memflow:memflow_password@localhost:5433/memflow
MEMFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
MEMFLOW_EMBEDDING_API_BASE=http://localhost:8001/v1 # Required
MEMFLOW_EMBEDDING_API_KEY=EMPTY
MEMFLOW_EMBEDDING_DIMENSIONS=2560
