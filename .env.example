# MemFlow Environment Configuration
# Copy this file to .env and customize as needed
# cp .env.example .env

# ===========================================
# LLM Configuration
# ===========================================
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_API_BASE=http://localhost:11434
LLM_API_KEY=

# ===========================================
# Storage Backend Selection
# ===========================================
# Options: emulated | file | memmachine
MEMFLOW_BACKEND=emulated
MEMFLOW_DATA_DIR=./memflow_data

# ===========================================
# MemMachine VectorDB
# Used when MEMFLOW_BACKEND=memmachine
# ===========================================
MEMMACHINE_BASE_URL=http://localhost:8080
MEMMACHINE_ORG_ID=default
MEMMACHINE_PROJECT=memflow
MEMMACHINE_API_KEY=
